# Phase 3 — Groq Inference API (https://console.groq.com/keys).
# Required for `python -m restaurant_rec recommend` with LLM; omit to use template fallback.
GROQ_API_KEY=

# Optional overrides (defaults are set in restaurant_rec.config).
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_TEMPERATURE=0.35
# GROQ_MAX_TOKENS=1024
# GROQ_TIMEOUT_SECONDS=60
# RECOMMENDATION_TOP_K=5

# Optional: Hugging Face token for gated datasets or higher rate limits.
HF_TOKEN=
